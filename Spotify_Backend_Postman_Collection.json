{
  "info": {
    "name": "Spotify Backend Application",
    "description": "Postman Collection for Spotify Backend APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\",\n    \"role\": \"user\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(jsonData.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Forget Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"john@example.com\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/forgetPassword", "host": ["{{base_url}}"], "path": ["auth", "forgetPassword"] }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"john@example.com\",\n    \"otp\": \"123456\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/verifyOtp", "host": ["{{base_url}}"], "path": ["auth", "verifyOtp"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"john@example.com\",\n    \"newPassword\": \"newpass123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/resetPassword", "host": ["{{base_url}}"], "path": ["auth", "resetPassword"] }
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{base_url}}/profile", "host": ["{{base_url}}"], "path": ["profile"] }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"John Updated\",\n    \"email\": \"john_updated@example.com\"\n}"
            },
            "url": { "raw": "{{base_url}}/profile", "host": ["{{base_url}}"], "path": ["profile"] }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"currentPassword\": \"password123\",\n    \"newPassword\": \"newpass123\"\n}"
            },
            "url": { "raw": "{{base_url}}/changePassword", "host": ["{{base_url}}"], "path": ["changePassword"] }
          }
        },
        {
          "name": "Get All Users (Admin)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{base_url}}/users", "host": ["{{base_url}}"], "path": ["users"] }
          }
        },
        {
          "name": "Update Role (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"role\": \"artist\"\n}"
            },
            "url": { "raw": "{{base_url}}/updateRole/1", "host": ["{{base_url}}"], "path": ["updateRole", "1"] }
          }
        },
        {
          "name": "Block User (Admin)",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{base_url}}/block/1", "host": ["{{base_url}}"], "path": ["block", "1"] }
          }
        },
        {
          "name": "Unblock User (Admin)",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{base_url}}/unblock/1", "host": ["{{base_url}}"], "path": ["unblock", "1"] }
          }
        },
        {
          "name": "Delete User (Admin)",
          "request": {
            "method": "DELETE",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{base_url}}/delete/1", "host": ["{{base_url}}"], "path": ["delete", "1"] }
          }
        }
      ]
    },
    {
      "name": "Music",
      "item": [
        {
          "name": "Create Music (Artist)",
          "request": {
            "method": "POST",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "My Awesome Song", "type": "text" },
                { "key": "music", "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{base_url}}/create", "host": ["{{base_url}}"], "path": ["create"] }
          }
        },
        {
          "name": "Get All Music (Admin)",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{base_url}}/all?page=1&limit=10", "host": ["{{base_url}}"], "path": ["all"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "10" }] }
          }
        },
        {
          "name": "Search Music",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{base_url}}/search/song-name", "host": ["{{base_url}}"], "path": ["search", "song-name"] }
          }
        },
        {
          "name": "Update Music (Artist/Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Updated Song Name\"\n}"
            },
            "url": { "raw": "{{base_url}}/update/1", "host": ["{{base_url}}"], "path": ["update", "1"] }
          }
        },
        {
          "name": "Delete Music (Artist/Admin)",
          "request": {
            "method": "DELETE",
            "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ],
            "url": { "raw": "{{base_url}}/delete/1", "host": ["{{base_url}}"], "path": ["delete", "1"] }
          }
        }
      ]
    },
    {
      "name": "Playlist",
      "item": [
        {
          "name": "Create Playlist",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"My Playlist\",\n    \"description\": \"Chill Vibes\",\n    \"image\": \"http://example.com/image.jpg\",\n    \"userId\": 1\n}"
            },
            "url": { "raw": "{{base_url}}/create", "host": ["{{base_url}}"], "path": ["create"] }
          }
        },
        {
          "name": "Get All Playlists",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/all", "host": ["{{base_url}}"], "path": ["all"] }
          }
        },
        {
          "name": "Add Song to Playlist",
          "request": {
            "method": "POST",
            "url": { "raw": "{{base_url}}/add/1/2", "host": ["{{base_url}}"], "path": ["add", "1", "2"] }
          }
        },
        {
          "name": "Remove Song from Playlist",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/remove/1/2", "host": ["{{base_url}}"], "path": ["remove", "1", "2"] }
          }
        },
        {
          "name": "Get Playlist With Songs",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/with-songs/1", "host": ["{{base_url}}"], "path": ["with-songs", "1"] }
          }
        }
      ]
    },
    {
      "name": "Like",
      "item": [
        {
          "name": "Like Music",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"userId\": 1,\n    \"musicId\": 2\n}"
            },
            "url": { "raw": "{{base_url}}/like", "host": ["{{base_url}}"], "path": ["like"] }
          }
        },
        {
          "name": "Unlike Music",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"userId\": 1,\n    \"musicId\": 2\n}"
            },
            "url": { "raw": "{{base_url}}/unlike", "host": ["{{base_url}}"], "path": ["unlike"] }
          }
        },
        {
          "name": "Get Liked Music by User",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/liked/1", "host": ["{{base_url}}"], "path": ["liked", "1"] }
          }
        }
      ]
    }
  ]
}