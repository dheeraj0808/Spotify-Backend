{
	"info": {
		"_postman_id": "e1dd8ac9-bd6a-4e06-9172-09ee966757df",
		"name": "Spotify Backend - LATEST",
		"description": "Clean and mapped collection based on CURRENT backend code.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{ "name": "Register", "request": { "method": "POST", "url": "{{base_url}}/api/auth/register", "body": { "mode": "raw", "raw": "{\n  \"name\": \"User\",\n  \"email\": \"test@test.com\",\n  \"password\": \"pass123\",\n  \"role\": \"user\"\n}", "options": { "raw": { "language": "json" } } } } },
				{ "name": "Login", "request": { "method": "POST", "url": "{{base_url}}/api/auth/login", "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"pass123\"\n}", "options": { "raw": { "language": "json" } } } } },
				{ "name": "Forget Password", "request": { "method": "POST", "url": "{{base_url}}/api/auth/forgetPassword", "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@test.com\"\n}", "options": { "raw": { "language": "json" } } } } },
				{ "name": "Verify OTP", "request": { "method": "POST", "url": "{{base_url}}/api/auth/verifyOtp", "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@test.com\",\n  \"otp\": \"123456\"\n}", "options": { "raw": { "language": "json" } } } } },
				{ "name": "Reset Password", "request": { "method": "POST", "url": "{{base_url}}/api/auth/resetPassword", "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@test.com\",\n  \"newPassword\": \"newpass123\"\n}", "options": { "raw": { "language": "json" } } } } }
			]
		},
		{
			"name": "Users",
			"item": [
				{ "name": "My Profile", "request": { "method": "GET", "url": "{{base_url}}/api/users/profile", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ] } },
				{ "name": "Update Profile", "request": { "method": "PUT", "url": "{{base_url}}/api/users/profile", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\"name\": \"Updated Name\"}", "options": { "raw": { "language": "json" } } } } },
				{ "name": "Admin: All Users", "request": { "method": "GET", "url": "{{base_url}}/api/users/users", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ] } },
				{ "name": "Change Password", "request": { "method": "PATCH", "url": "{{base_url}}/api/users/changePassword", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\"currentPassword\": \"old\", \"newPassword\": \"new\"}", "options": { "raw": { "language": "json" } } } } },
				{ "name": "Admin: Delete User", "request": { "method": "DELETE", "url": "{{base_url}}/api/users/delete/:id", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "variable": [ { "key": "id", "value": "" } ] } },
				{ "name": "Admin: Update Role", "request": { "method": "PATCH", "url": "{{base_url}}/api/users/updateRole/:id", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "variable": [ { "key": "id", "value": "" } ], "body": { "mode": "raw", "raw": "{\"role\": \"artist\"}", "options": { "raw": { "language": "json" } } } } },
				{ "name": "Admin: Block User", "request": { "method": "PATCH", "url": "{{base_url}}/api/users/block/:id", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "variable": [ { "key": "id", "value": "" } ] } },
				{ "name": "Admin: Unblock User", "request": { "method": "PATCH", "url": "{{base_url}}/api/users/unblock/:id", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "variable": [ { "key": "id", "value": "" } ] } }
			]
		},
		{
			"name": "Music",
			"item": [
				{ "name": "Create Music (Artist)", "request": { "method": "POST", "url": "{{base_url}}/api/music/create", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "formdata", "formdata": [ { "key": "title", "value": "Song Title", "type": "text" }, { "key": "music", "type": "file", "src": [] } ] } } },
				{ "name": "Admin: List All", "request": { "method": "GET", "url": "{{base_url}}/api/music/all", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ] } },
				{ "name": "Search Music", "request": { "method": "GET", "url": "{{base_url}}/api/music/search/:name", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "variable": [ { "key": "name", "value": "song_name" } ] } },
				{ "name": "Update Music", "request": { "method": "PUT", "url": "{{base_url}}/api/music/update/:id", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "variable": [ { "key": "id", "value": "" } ], "body": { "mode": "raw", "raw": "{\"title\": \"New Title\"}", "options": { "raw": { "language": "json" } } } } },
				{ "name": "Delete Music", "request": { "method": "DELETE", "url": "{{base_url}}/api/music/delete/:id", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "variable": [ { "key": "id", "value": "" } ] } }
			]
		},
		{
			"name": "Playlists",
			"item": [
				{ "name": "Create Playlist", "request": { "method": "POST", "url": "{{base_url}}/api/playlist/create", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\"name\": \"Hits\", \"description\": \"Best\", \"image\": \"url\"}", "options": { "raw": { "language": "json" } } } } },
				{ "name": "My Playlists", "request": { "method": "GET", "url": "{{base_url}}/api/playlist/all", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ] } },
				{ "name": "Add Music to Playlist", "request": { "method": "POST", "url": "{{base_url}}/api/playlist/add/:playlistId/:musicId", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "variable": [ { "key": "playlistId", "value": "" }, { "key": "musicId", "value": "" } ] } },
				{ "name": "Remove Music from Playlist", "request": { "method": "DELETE", "url": "{{base_url}}/api/playlist/remove/:playlistId/:musicId", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "variable": [ { "key": "playlistId", "value": "" }, { "key": "musicId", "value": "" } ] } },
				{ "name": "Playlist Details (with songs)", "request": { "method": "GET", "url": "{{base_url}}/api/playlist/with-songs/:playlistId", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "variable": [ { "key": "playlistId", "value": "" } ] } }
			]
		},
		{
			"name": "Likes",
			"item": [
				{ "name": "Like Music", "request": { "method": "POST", "url": "{{base_url}}/api/like/like", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\"musicId\": \"id\"}", "options": { "raw": { "language": "json" } } } } },
				{ "name": "Unlike Music", "request": { "method": "POST", "url": "{{base_url}}/api/like/unlike", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "body": { "mode": "raw", "raw": "{\"musicId\": \"id\"}", "options": { "raw": { "language": "json" } } } } },
				{ "name": "List Liked Music", "request": { "method": "GET", "url": "{{base_url}}/api/like/liked/:userId", "header": [ { "key": "Authorization", "value": "Bearer {{token}}" } ], "variable": [ { "key": "userId", "value": "" } ] } }
			]
		}
	],
	"variable": [
		{ "key": "base_url", "value": "http://localhost:5000" },
		{ "key": "token", "value": "your_jwt_token_here" }
	]
}